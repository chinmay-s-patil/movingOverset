FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    overset
    {
        type            overset;
		value			uniform 0;
    }

    "(movingObstacle|walls|inlet|inlet1)"
    {
        type            fixedFluxPressure;
    }
	
	outlet
	{
		type			fixedValue;
		value			uniform 0;
	}

	frontAndBack
    {
        type            empty;
    }
}

